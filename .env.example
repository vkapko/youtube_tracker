# API server
PORT=3001

# SQLite database file path (relative to repo root)
DATABASE_PATH=data/db.sqlite

# Transcripts and summaries on disk (relative to repo root)
DATA_DIR=data

# YouTube Data API v3 key
YOUTUBE_API_KEY=

# Anthropic API key (for summarization and chat)
ANTHROPIC_API_KEY=

# Chroma vector store
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=youtube_tracker

# Channel sync schedule (hours between automatic syncs)
SYNC_INTERVAL_HOURS=24
