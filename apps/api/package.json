{
  "name": "@youtube-tracker/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
